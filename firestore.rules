rules_version = '2';
// spain0511 공용 — mongolia-mission-app + yeohaeng-jugwon 동일 파일 유지
// 변경 후: npm run sync:firebase-rules → firebase deploy --only firestore:rules,storage
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isTripMember(tripId) {
      let trip = get(/databases/$(database)/documents/trips/$(tripId));
      return signedIn()
        && trip.data != null
        && (
          trip.data.ownerId == request.auth.uid
          || (
            trip.data.keys().hasAll(['memberIds'])
            && request.auth.uid in trip.data.memberIds
          )
        );
    }

    // --- 몽골선교 (missions/riseup-mongolia-2026/albumPhotos) ---
    match /missions/{missionId}/albumPhotos/{photoId} {
      allow read, create: if signedIn();
      allow delete: if signedIn();
      allow update: if false;
    }

    // --- 여행주권 ---
    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
    }

    match /trips/{tripId} {
      allow read: if signedIn()
        && (
          resource.data.ownerId == request.auth.uid
          || (
            resource.data.keys().hasAll(['memberIds'])
            && request.auth.uid in resource.data.memberIds
          )
        );

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      allow update: if signedIn()
        && request.resource.data.ownerId == resource.data.ownerId
        && (
          resource.data.ownerId == request.auth.uid
          || (
            resource.data.keys().hasAll(['memberIds'])
            && request.auth.uid in resource.data.memberIds
          )
        );

      allow delete: if signedIn()
        && resource.data.ownerId == request.auth.uid;

      match /tickets/{ticketId} {
        allow read, write: if isTripMember(tripId);
      }

      match /albumPhotos/{photoId} {
        allow read, write: if isTripMember(tripId);
      }

      match /tripExpenses/{expenseId} {
        allow read, write: if isTripMember(tripId);
      }

      match /aiSchedules/{scheduleId} {
        allow read, write: if isTripMember(tripId);
      }

      match /restaurantPicks/{pickId} {
        allow read, write: if isTripMember(tripId);
      }
    }

    // 구 (단일 여행) 호환 — 마이그레이션 기간 동안 인증 사용자만
    match /tickets/{ticketId} {
      allow read, write: if signedIn();
    }

    match /albumPhotos/{photoId} {
      allow read, write: if signedIn();
    }

    match /tripExpenses/{expenseId} {
      allow read, write: if signedIn();
    }
  }
}
