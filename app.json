{
  "expo": {
    "name": "2026 Rise Up 몽골선교",
    "slug": "mongolia-mission-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yeun.riseupmongolia"
    },
    "android": {
