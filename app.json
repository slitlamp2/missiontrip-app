{
  "expo": {
    "name": "RiseUp",
    "slug": "mongolia-mission-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1F26"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yeun.riseupmongolia",
      "infoPlist": {
        "CFBundleDisplayName": "RiseUp",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "공유 앨범에 사진·동영상을 올리기 위해 사진 라이브러리 접근이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "공유 앨범의 사진·동영상을 폰에 저장하려면 권한이 필요합니다."
      }
    },
    "android": {
      "package": "com.yeun.riseupmongolia",
      "adaptiveIcon": {
        "backgroundColor": "#87CEEB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "공유 앨범에 사진·동영상을 올리기 위해 사진 라이브러리 접근이 필요합니다."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "공유 앨범의 사진·동영상을 폰에 저장·불러오기 위해 접근합니다.",
          "savePhotosPermission": "공유 앨범의 사진·동영상을 폰에 저장하려면 권한이 필요합니다.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "1fe98eee-8c99-45df-b93c-7998305f1be7"
      }
    },
    "owner": "slitlamp2"
  }
}
